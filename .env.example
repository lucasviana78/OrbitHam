# ---- Database (PostgreSQL 17) ----
POSTGRES_DB=orbitham
POSTGRES_USER=orbitham
POSTGRES_PASSWORD=orbitham
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Django backend ----
DJANGO_SECRET_KEY=dev-insecure-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
# Cookies: Secure=false in local dev (no HTTPS on localhost)
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
CELERY_BROKER_URL=redis://redis:6379/0

# Demo seed user (created by `manage.py seed_demo`)
DEMO_USER_EMAIL=demo@orbitham.com
DEMO_USER_PASSWORD=demo12345

# ---- Frontend (Next.js) ----
# Same-origin through nginx; browser calls relative /api
NEXT_PUBLIC_API_BASE_URL=/api

# ---- N2YO (fonte secundária de TLE) ----
N2YO_API_KEY=your-n2yo-api-key-here
